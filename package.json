{
  "name": "opentuwa",
  "version": "2.0.0",
  "private": true,
  "description": "Tuwa - Premium Quran Audio Player (Next.js + Tailwind)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name=opentuwa",
    "pages:preview": "npm run pages:build && wrangler pages dev .vercel/output/static"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.0.0",
    "@cloudflare/workers-types": "^4.20260620.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.103.0"
  }
}
